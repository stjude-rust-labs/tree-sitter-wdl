    "description": "Tree-sitter grammar for WDL (Workflow Description Language)",
    "authors": [
      {
        "name": "St. Jude Rust Labs"
      }
    ],
    "links": {
      "repository": "https://github.com/stjude-rust-labs/tree-sitter-wdl"
    }
  }
}
